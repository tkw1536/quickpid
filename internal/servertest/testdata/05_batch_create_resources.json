              "tag": "",
              "deleted": false
            }
          ]
        }
      }
    },
    {
      "name": "tooManyItems",
      "config": {
        "namespaceIDs": [],
        "pids": [],
        "now": "2020-01-02T03:04:05Z"
      },
      "limits": { "MaxBatchItems": 2 },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces/46c14e5d-c048-4159-a26a-f37bc0110c85/resources:batch",
        "body": "[{\"url\":\"https://b1\",\"metadata\":\"b1@batch\",\"tag\":\"\"},{\"url\":\"https://b2\",\"metadata\":\"b2@batch\",\"tag\":\"\"},{\"url\":\"https://b3\",\"metadata\":\"b3@batch\",\"tag\":\"\"}]"
      },
      "response": {
        "status": 400,
        "body": {
          "json": {
            "error": "too many items: 3 > 2"
          }
        }
      }
    },
    {
      "name": "namespaceMissing",
      "config": {
        "namespaceIDs": [],
        "pids": [],
        "now": "2020-01-02T03:04:05Z"
      },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces/missing/resources:batch",
        "body": "[{\"url\":\"https://x\",\"metadata\":null,\"tag\":\"\"}]"
      },
      "response": {
        "status": 404,
        "body": {
          "json": {
            "error": "namespace not found"
          }
        }
      }
    },
    {
      "name": "tooLargeBody",
      "config": {
        "namespaceIDs": [],
        "pids": [],
        "now": "2020-01-02T03:04:05Z"
      },
      "limits": { "MaxBodyBytes": 256 },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces/46c14e5d-c048-4159-a26a-f37bc0110c85/resources:batch",
        "body": "[{\"url\":\"https:\",\"metadata\":\"x\",\"tag\":\"\"}]"
      },
      "response": {
        "status": 413,
        "body": {
          "json": {
            "error": "request payload too large"
          }
