        ],
        "pids": [],
        "now": "2020-01-02T03:04:05Z"
      },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"flow-tag\",\"pid_format\":{\"pattern\":\"***-***\",\"characters\":\"full\"}}"
      },
      "response": {
        "status": 201,
        "body": {
          "json": {
            "id": "46c14e5d-c048-4159-a26a-f37bc0110c85",
            "tag": "flow-tag",
            "pid_format": {
              "pattern": "***-***",
              "characters": "full"
            },
            "date_created": "2020-01-02T03:04:05Z"
          }
        }
      }
    },
    {
      "name": "emptyBody",
      "config": {
        "namespaceIDs": [],
        "pids": [],
        "now": "2020-01-02T03:04:05Z"
      },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces"
      },
      "response": {
        "status": 400,
        "body": {
          "json": {
            "error": "body_missing"
          }
        }
      }
    },
    {
      "name": "trailingJSON",
      "config": {
        "namespaceIDs": [],
        "pids": [],
        "now": "2020-01-02T03:04:05Z"
      },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"x\",\"pid_format\":{\"pattern\":\"***\",\"characters\":\"full\"}} {\"tag\":\"y\"}"
      },
      "response": {
        "status": 400,
        "body": {
          "json": {
            "error": "body_trailing_json"
          }
        }
      }
    },
    {
      "name": "tooLargeBody",
      "config": {
        "namespaceIDs": [],
        "pids": [],
        "now": "2020-01-02T03:04:05Z"
      },
      "limits": { "MaxBodyBytes": 256 },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"\",\"pid_format\":{\"pattern\":\"***\",\"characters\":\"full\"}}"
      },
      "response": {
        "status": 413,
        "body": {
          "json": {
            "error": "body_size_exceeded"
          }
        }
      }
