{
  "name": "create_namespace",
  "comment": "Create namespace success and error cases.",
  "steps": [
    {
      "name": "success",
      "config": {
        "namespaceIDs": [
          "fake-namespace-id"
        ],
        "now": "2020-01-02T03:04:05Z"
      },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"flow-tag\",\"pid_format\":{\"pattern\":\"***-***\",\"characters\":\"full\"}}"
      },
      "response": {
        "status": 201,
        "body": {
          "json": {
            "id": "fake-namespace-id",
            "tag": "flow-tag",
            "pid_format": {
              "pattern": "***-***",
              "characters": "full"
            },
            "date_created": "2020-01-02T03:04:05Z"
          }
        }
      }
    },
    {
      "name": "emptyBody",
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces"
      },
      "response": {
        "status": 400,
        "body": {
          "json": {
            "error": "body_missing"
          }
        }
      }
    },
    {
      "name": "trailingJSON",
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"x\",\"pid_format\":{\"pattern\":\"***\",\"characters\":\"full\"}} {\"tag\":\"y\"}"
      },
      "response": {
        "status": 400,
        "body": {
          "json": {
            "error": "body_invalid_json"
          }
        }
      }
    },
    {
      "name": "tooLargeBody",
      "limits": {
        "MaxBodyBytes": 256
      },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"\",\"pid_format\":{\"pattern\":\"***\",\"characters\":\"full\"}}"
      },
      "response": {
        "status": 413,
        "body": {
          "json": {
            "error": "body_size_exceeded"
          }
        }
      }
    },
    {
      "name": "malformedJSON",
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{"
      },
      "response": {
        "status": 400,
        "body": {
          "json": {
            "error": "body_invalid_json"
          }
        }
      }
    },
    {
      "name": "invalidPatternInBody",
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"t\",\"pid_format\":{\"pattern\":\"!!not-a-valid-pattern!!\",\"characters\":\"full\"}}"
      },
      "response": {
        "status": 400,
        "body": {
          "json": {
            "error": "body_invalid_json"
          }
        }
      }
    },
    {
      "name": "badIDGeneration_error",
      "config": {
        "namespaceIDs": []
      },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"t\",\"pid_format\":{\"pattern\":\"***\",\"characters\":\"full\"}}"
      },
      "response": {
        "status": 500,
        "body": {
          "json": {
            "error": "bad_id_generation"
          }
        }
      }
    },

    {
      "name": "insufficientEntropy_fail",
      "config": {
        "namespaceIDs": [
          "fake-namespace-id"
        ],
        "now": "2020-01-02T03:04:05.000Z"
      },
      "limits": {
        "MaxNamespaceIDAttempts": 1
      },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"seed-dup\",\"pid_format\":{\"pattern\":\"***-***\",\"characters\":\"full\"}}"
      },
      "response": {
        "status": 503,
        "body": {
          "json": {
            "error": "insufficient_entropy"
          }
        }
      }
    },
    {
      "name": "insufficientEntropy_success",
      "config": {
        "namespaceIDs": [
          "fake-namespace-id",
          "fake-namespace-id",
          "another-one"
        ],
        "now": "2020-01-02T03:04:05Z"
      },
      "limits": {
        "MaxNamespaceIDAttempts": 3
      },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"t2\",\"pid_format\":{\"pattern\":\"***-***\",\"characters\":\"full\"}}"
      },
      "response": {
        "status": 201,
        "body": {
          "json": {
            "id": "another-one",
            "tag": "t2",
            "pid_format": {
              "pattern": "***-***",
              "characters": "full"
            },
            "date_created": "2020-01-02T03:04:05Z"
          }
        }
      }
    }
  ]
}