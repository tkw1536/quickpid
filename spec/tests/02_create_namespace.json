{
  "name": "create_namespace",
  "comment": "Create namespace success and error cases.",
  "steps": [
    {
      "name": "success",
      "config": {
        "namespaceIDs": [
          "fake-namespace-id"
        ],
        "now": "2020-01-02T03:04:05Z"
      },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"flow-tag\",\"pid_format\":{\"pattern\":\"***-***\",\"characters\":\"full\"}}"
      },
      "response": {
        "code": 201,
        "body": {
          "date_created": "2020-01-02T03:04:05Z",
          "id": "fake-namespace-id",
          "pid_format": {
            "characters": "full",
            "pattern": "***-***"
          },
          "tag": "flow-tag"
        }
      }
    },
    {
      "name": "emptyBody",
      "config": {},
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces"
      },
      "response": {
        "code": 400,
        "body": {
          "error": "body_missing"
        }
      }
    },
    {
      "name": "trailingJSON",
      "config": {},
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"x\",\"pid_format\":{\"pattern\":\"***\",\"characters\":\"full\"}} {\"tag\":\"y\"}"
      },
      "response": {
        "code": 400,
        "body": {
          "error": "body_invalid_json"
        }
      }
    },
    {
      "name": "tooLargeBody",
      "config": {},
      "limits": {
        "MaxBodyBytes": 256,
        "DefaultPageLimit": 0,
        "MaxPageLimit": 0,
        "MaxBatchItems": 0,
        "MaxNamespaceIDAttempts": 0,
        "MaxPIDAttempts": 0
      },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"\",\"pid_format\":{\"pattern\":\"***\",\"characters\":\"full\"}}"
      },
      "response": {
        "code": 413,
        "body": {
          "error": "body_size_exceeded"
        }
      }
    },
    {
      "name": "malformedJSON",
      "config": {},
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{"
      },
      "response": {
        "code": 400,
        "body": {
          "error": "body_invalid_json"
        }
      }
    },
    {
      "name": "invalidPatternInBody",
      "config": {},
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"t\",\"pid_format\":{\"pattern\":\"!!not-a-valid-pattern!!\",\"characters\":\"full\"}}"
      },
      "response": {
        "code": 400,
        "body": {
          "error": "body_invalid_json"
        }
      }
    },
    {
      "name": "badIDGeneration_error",
      "config": {
        "namespaceIDs": []
      },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"t\",\"pid_format\":{\"pattern\":\"***\",\"characters\":\"full\"}}"
      },
      "response": {
        "code": 500,
        "body": {
          "error": "bad_id_generation"
        }
      }
    },
    {
      "name": "insufficientEntropy_fail",
      "config": {
        "namespaceIDs": [
          "fake-namespace-id"
        ],
        "now": "2020-01-02T03:04:05Z"
      },
      "limits": {
        "MaxBodyBytes": 0,
        "DefaultPageLimit": 0,
        "MaxPageLimit": 0,
        "MaxBatchItems": 0,
        "MaxNamespaceIDAttempts": 1,
        "MaxPIDAttempts": 0
      },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"seed-dup\",\"pid_format\":{\"pattern\":\"***-***\",\"characters\":\"full\"}}"
      },
      "response": {
        "code": 503,
        "body": {
          "error": "insufficient_entropy"
        }
      }
    },
    {
      "name": "insufficientEntropy_success",
      "config": {
        "namespaceIDs": [
          "fake-namespace-id",
          "fake-namespace-id",
          "another-one"
        ],
        "now": "2020-01-02T03:04:05Z"
      },
      "limits": {
        "MaxBodyBytes": 0,
        "DefaultPageLimit": 0,
        "MaxPageLimit": 0,
        "MaxBatchItems": 0,
        "MaxNamespaceIDAttempts": 3,
        "MaxPIDAttempts": 0
      },
      "request": {
        "method": "POST",
        "path": "/resolver/namespaces",
        "body": "{\"tag\":\"t2\",\"pid_format\":{\"pattern\":\"***-***\",\"characters\":\"full\"}}"
      },
      "response": {
        "code": 201,
        "body": {
          "date_created": "2020-01-02T03:04:05Z",
          "id": "another-one",
          "pid_format": {
            "characters": "full",
            "pattern": "***-***"
          },
          "tag": "t2"
        }
      }
    }
  ]
}
