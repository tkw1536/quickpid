{
  "name": "get_resolver",
  "comment": "GET /resolver info endpoint and error cases.",
  "steps": [
    {
      "name": "info_ok",
      "config": {
        "infoEnabled": true
      },
      "limits": {
        "MaxBodyBytes": 1048576,
        "DefaultPageLimit": 100,
        "MaxPageLimit": 1000,
        "MaxBatchItems": 100,
        "MaxNamespaceIDAttempts": 100,
        "MaxPIDAttempts": 100
      },
      "request": {
        "method": "GET",
        "path": "/resolver"
      },
      "response": {
        "code": 200,
        "body": {
          "default_page_limit": 100,
          "max_batch_items": 100,
          "max_body_bytes": 1048576,
          "max_page_limit": 1000
        }
      }
    },
    {
      "name": "info_unavailable",
      "config": {
        "infoEnabled": false
      },
      "request": {
        "method": "GET",
        "path": "/resolver"
      },
      "response": {
        "code": 404,
        "body": {
          "error": "info_unavailable"
        }
      }
    }
  ]
}
